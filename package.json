{
  "name": "openchat-react-mobile",
  "private": true,
  "version": "1.0.0",
  "description": "OpenChat Mobile - A React + Capacitor mobile application with modular architecture",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite --mode development",
    "dev:staging": "vite --mode staging",
    "dev:ios": "pnpm cap:sync && pnpm cap:open:ios",
    "dev:android": "pnpm cap:sync && pnpm cap:open:android",
    "build": "tsc && vite build",
    "build:staging": "tsc && vite build --mode staging",
    "build:app": "pnpm build && pnpm cap:sync",
    "build:packages": "pnpm --filter ./packages/** build",
    "preview": "vite preview",
    "cap:add:ios": "pnpm exec cap add ios",
    "cap:add:android": "pnpm exec cap add android",
    "cap:sync": "pnpm exec cap sync",
    "cap:copy": "pnpm exec cap copy",
    "cap:open:ios": "pnpm exec cap open ios",
    "cap:open:android": "pnpm exec cap open android",
    "cap:ios": "pnpm cap:open:ios",
    "cap:android": "pnpm cap:open:android",
    "cap:run:ios": "pnpm exec cap run ios",
    "cap:run:android": "pnpm exec cap run android",
    "cap:doctor": "pnpm exec cap doctor",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "format": "pnpm -r format",
    "format:check": "pnpm -r format:check",
    "validate:service-standard": "node scripts/validate-service-standard.mjs",
    "validate:encoding": "node scripts/validate-encoding.mjs",
    "validate:encoding:strict": "node scripts/validate-encoding.mjs --strict",
    "validate:standards": "pnpm validate:service-standard && pnpm validate:encoding:strict",
    "check:sdk-standard": "node ../scripts/check-sdk-compliance.mjs --strict && node ../scripts/check-auth-standard.mjs && node ../scripts/check-user-center-standard.mjs && node ../scripts/check-vip-standard.mjs && node ../scripts/check-contacts-standard.mjs && node ../scripts/check-product-standard.mjs && node ../scripts/check-drive-standard.mjs && node ../scripts/check-notification-standard.mjs && node ../scripts/check-trade-standard.mjs",
    "check:sdk-standard:quick": "node ../scripts/check-auth-standard.mjs && node ../scripts/check-user-center-standard.mjs && node ../scripts/check-vip-standard.mjs && node ../scripts/check-contacts-standard.mjs && node ../scripts/check-product-standard.mjs && node ../scripts/check-drive-standard.mjs && node ../scripts/check-notification-standard.mjs && node ../scripts/check-trade-standard.mjs",
    "test": "pnpm -r test",
    "test:run": "pnpm -r test:run",
    "clean": "pnpm -r clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build:packages && changeset publish",
    "install:all": "pnpm install",
    "dev:core": "pnpm --filter @sdkwork/react-mobile-core dev",
    "dev:commons": "pnpm --filter @sdkwork/react-mobile-commons dev",
    "dev:auth": "pnpm --filter @sdkwork/react-mobile-auth dev",
    "dev:chat": "pnpm --filter @sdkwork/react-mobile-chat dev",
    "dev:user": "pnpm --filter @sdkwork/react-mobile-user dev",
    "dev:contacts": "pnpm --filter @sdkwork/react-mobile-contacts dev",
    "dev:commerce": "pnpm --filter @sdkwork/react-mobile-commerce dev",
    "dev:creation": "pnpm --filter @sdkwork/react-mobile-creation dev",
    "dev:social": "pnpm --filter @sdkwork/react-mobile-social dev",
    "dev:wallet": "pnpm --filter @sdkwork/react-mobile-wallet dev",
    "dev:settings": "pnpm --filter @sdkwork/react-mobile-settings dev",
    "dev:search": "pnpm --filter @sdkwork/react-mobile-search dev",
    "dev:notification": "pnpm --filter @sdkwork/react-mobile-notification dev",
    "dev:discover": "pnpm --filter @sdkwork/react-mobile-discover dev",
    "dev:drive": "pnpm --filter @sdkwork/react-mobile-drive dev",
    "dev:nearby": "pnpm --filter @sdkwork/react-mobile-nearby dev",
    "dev:appointments": "pnpm --filter @sdkwork/react-mobile-appointments dev",
    "dev:communication": "pnpm --filter @sdkwork/react-mobile-communication dev",
    "dev:tools": "pnpm --filter @sdkwork/react-mobile-tools dev",
    "dev:video": "pnpm --filter @sdkwork/react-mobile-video dev",
    "dev:content": "pnpm --filter @sdkwork/react-mobile-content dev",
    "dev:agents": "pnpm --filter @sdkwork/react-mobile-agents dev"
  },
  "dependencies": {
    "@capacitor/app": "catalog:",
    "@capacitor/app-launcher": "catalog:",
    "@capacitor/camera": "catalog:",
    "@capacitor/clipboard": "catalog:",
    "@capacitor/core": "catalog:",
    "@capacitor/device": "catalog:",
    "@capacitor/filesystem": "catalog:",
    "@capacitor/haptics": "catalog:",
    "@capacitor/keyboard": "catalog:",
    "@capacitor/local-notifications": "catalog:",
    "@capacitor/network": "catalog:",
    "@capacitor/preferences": "catalog:",
    "@capacitor/push-notifications": "catalog:",
    "@capacitor/share": "catalog:",
    "@capacitor/splash-screen": "catalog:",
    "@capacitor/status-bar": "catalog:",
    "@sdkwork/app-sdk": "workspace:*",
    "@google/genai": "^1.43.0",
    "@tiptap/core": "catalog:",
    "@tiptap/extension-placeholder": "catalog:",
    "@tiptap/react": "catalog:",
    "@tiptap/starter-kit": "catalog:",
    "classnames": "catalog:",
    "date-fns": "catalog:",
    "i18next": "catalog:",
    "immer": "catalog:",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-i18next": "catalog:",
    "react-router-dom": "catalog:",
    "uuid": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@capacitor/android": "catalog:",
    "@capacitor/cli": "catalog:",
    "@capacitor/ios": "catalog:",
    "@changesets/cli": "^2.29.8",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/react": "catalog:",
    "@types/node": "^25.3.1",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/uuid": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tailwindcss": "^4.2.1",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vite-plugin-pwa": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.6.5"
}
