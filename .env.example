# SDKWork Environment Configuration
# Copy this file to .env.local for local development

# ============================================
# Application Environment
# ============================================
# Options: development | staging | production
VITE_APP_ENV=development

# ============================================
# API Configuration
# ============================================
# Main API
# Development
VITE_API_BASE_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws

# Staging (uncomment for staging builds)
# VITE_API_BASE_URL=https://staging-api.sdkwork.com
# VITE_WS_URL=wss://staging-api.sdkwork.com/ws

# Production (uncomment for production builds)
# VITE_API_BASE_URL=https://api.sdkwork.com
# VITE_WS_URL=wss://api.sdkwork.com/ws

# IM (Instant Messaging) API
# Development
VITE_IM_API_BASE_URL=http://localhost:8081

# Staging (uncomment for staging builds)
# VITE_IM_API_BASE_URL=https://staging-im-api.sdkwork.com

# Production (uncomment for production builds)
# VITE_IM_API_BASE_URL=https://im-api.sdkwork.com

# ============================================
# Authentication
# ============================================
# API Key for external services
VITE_API_KEY=

# Access token for SDK authentication (required)
VITE_ACCESS_TOKEN=

# ============================================
# Multi-tenancy
# ============================================
VITE_TENANT_ID=
VITE_ORGANIZATION_ID=

# ============================================
# Platform
# Options: web | tauri | electron | mobile
# ============================================
VITE_PLATFORM=mobile

# ============================================
# Capacitor Native Live Reload (Optional)
# Only set this when debugging native shells against `pnpm dev`.
# Example: CAP_SERVER_URL=http://192.168.1.23:3000
# ============================================
# CAP_SERVER_URL=

# Compatibility fallback keys (for shared SDK bootstrap)
VITE_APP_API_BASE_URL=http://localhost:8080
SDKWORK_API_BASE_URL=http://localhost:8080
SDKWORK_ACCESS_TOKEN=
SDKWORK_TENANT_ID=
SDKWORK_ORGANIZATION_ID=
SDKWORK_PLATFORM=mobile

# ============================================
# Debug Settings
# ============================================
VITE_DEBUG=true
VITE_LOG_LEVEL=debug

# ============================================
# Feature Flags
# ============================================
# Analytics (typically enabled in production)
VITE_FEATURE_ANALYTICS=false

# Push Notifications
VITE_FEATURE_NOTIFICATIONS=true

# WebSocket Support
VITE_FEATURE_WEBSOCKET=true

# Caching (typically enabled in production/staging)
VITE_FEATURE_CACHE=false

# ============================================
# Request Configuration
# ============================================
# Timeout in milliseconds
VITE_TIMEOUT=30000

# ============================================
# AI/ML API Keys (Optional)
# ============================================
# Google Gemini
VITE_GEMINI_API_KEY=

# OpenAI
VITE_OPENAI_API_KEY=

# AWS
VITE_AWS_ACCESS_KEY_ID=
VITE_AWS_SECRET_ACCESS_KEY=
VITE_AWS_REGION=
VITE_AWS_S3_BUCKET=
