{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "declaration": true,
    "declarationMap": true,
    "baseUrl": ".",
    "paths": {
      "@sdkwork/react-mobile-core": ["../sdkwork-react-mobile-core/src/index.ts"],
      "@sdkwork/react-mobile-core/*": ["../sdkwork-react-mobile-core/src/*"],
      "@sdkwork/react-mobile-commons": ["../sdkwork-react-mobile-commons/src/index.ts"],
      "@sdkwork/react-mobile-commons/*": ["../sdkwork-react-mobile-commons/src/*"],
      "@sdkwork/react-mobile-auth": ["../sdkwork-react-mobile-auth/src/index.ts"],
      "@sdkwork/react-mobile-auth/*": ["../sdkwork-react-mobile-auth/src/*"],
      "@sdkwork/react-mobile-user": ["../sdkwork-react-mobile-user/src/index.ts"],
      "@sdkwork/react-mobile-user/*": ["../sdkwork-react-mobile-user/src/*"]
    }
  },
  "include": ["src/**/*"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
