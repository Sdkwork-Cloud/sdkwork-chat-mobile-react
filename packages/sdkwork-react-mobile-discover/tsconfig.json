{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@sdkwork/react-mobile-core": ["../sdkwork-react-mobile-core/src/index.ts"],
      "@sdkwork/react-mobile-core/*": ["../sdkwork-react-mobile-core/src/*"],
      "@sdkwork/react-mobile-commons": ["../sdkwork-react-mobile-commons/src/index.ts"],
      "@sdkwork/react-mobile-commons/*": ["../sdkwork-react-mobile-commons/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
