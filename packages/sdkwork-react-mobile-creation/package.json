{
  "name": "@sdkwork/react-mobile-creation",
  "version": "1.0.0",
  "description": "Creation module for OpenChat React Mobile - AI Image, Video, Music Generation",
  "main": "./dist/index.umd.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "dev": "vite build --watch",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:",
    "@sdkwork/react-mobile-core": "workspace:*",
    "@sdkwork/react-mobile-commons": "workspace:*",
    "@sdkwork/react-mobile-auth": "workspace:*",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:"
  }
}
