# Development Environment
# Local development configuration

# ============================================
# Application Environment
# ============================================
VITE_APP_ENV=development

# ============================================
# API Configuration
# ============================================
# Main API
VITE_API_BASE_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws

# IM (Instant Messaging) API
VITE_IM_API_BASE_URL=http://localhost:8081

# ============================================
# Platform
# ============================================
VITE_PLATFORM=mobile

# ============================================
# Capacitor Native Live Reload (Optional)
# Set to your LAN IP when running on device/emulator.
# Example: CAP_SERVER_URL=http://192.168.1.23:3000
# ============================================
# CAP_SERVER_URL=

# ============================================
# Debug Settings
# ============================================
VITE_DEBUG=true
VITE_LOG_LEVEL=debug

# ============================================
# Feature Flags
# ============================================
VITE_FEATURE_ANALYTICS=false
VITE_FEATURE_NOTIFICATIONS=true
VITE_FEATURE_WEBSOCKET=true
VITE_FEATURE_CACHE=false

# ============================================
# Authentication
# ============================================
VITE_ACCESS_TOKEN=

# ============================================
# Request Configuration
# ============================================
VITE_TIMEOUT=30000
